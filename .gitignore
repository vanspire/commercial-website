# ============================================
# 🚀 NEXT.JS + NODE FULLSTACK .GITIGNORE
# ============================================

# --------------------------------------------
# 1️⃣ Node Modules
# --------------------------------------------
node_modules/
.pnp
.pnp.js

# --------------------------------------------
# 2️⃣ Next.js
# --------------------------------------------
.next/
out/
.next-cache/
.vercel/

# Next build output
build/

# --------------------------------------------
# 3️⃣ TypeScript
# --------------------------------------------
*.tsbuildinfo

# --------------------------------------------
# 4️⃣ Environment Files (VERY IMPORTANT)
# --------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# --------------------------------------------
# 5️⃣ Logs
# --------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --------------------------------------------
# 6️⃣ Runtime Data
# --------------------------------------------
pids
*.pid
*.seed
*.pid.lock

# --------------------------------------------
# 7️⃣ Coverage & Testing
# --------------------------------------------
coverage/
.nyc_output/
jest-cache/
cypress/videos/
cypress/screenshots/
playwright-report/

# --------------------------------------------
# 8️⃣ Database / Prisma
# --------------------------------------------
prisma/*.db
prisma/*.db-journal

# If using SQLite locally
*.sqlite
*.sqlite3

# --------------------------------------------
# 9️⃣ Build Artifacts
# --------------------------------------------
dist/
.eslintcache
.cache/

# --------------------------------------------
# 🔟 Docker
# --------------------------------------------
.dockerignore
docker-compose.override.yml

# --------------------------------------------
# 1️⃣1️⃣ IDE & Editor
# --------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# --------------------------------------------
# 1️⃣2️⃣ OS Files
# --------------------------------------------
.DS_Store
Thumbs.db

# --------------------------------------------
# 1️⃣3️⃣ Misc
# --------------------------------------------
*.tgz
*.bak
*.tmp
*.temp

# --------------------------------------------
# 1️⃣4️⃣ Vercel
# --------------------------------------------
.vercel

# --------------------------------------------
# 1️⃣5️⃣ Local uploads (if any)
# --------------------------------------------
public/uploads/
uploads/

# --------------------------------------------
# 1️⃣6️⃣ Generated API docs
# --------------------------------------------
docs/generated/

# --------------------------------------------
# 1️⃣7️⃣ Debug
# --------------------------------------------
*.swp
*.swo
